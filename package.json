{
  "name": "z-desktop-agent",
  "version": "1.0.1",
  "description": "AI Desktop Agent - Controle seu computador com IA",
  "main": "src/main/main.js",
  "homepage": "https://github.com/Pedro21062014/z-desktop-agent",
  "author": "Pedro21062014",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "electron .",
    "dev:renderer": "webpack serve --config webpack.renderer.js --mode development",
    "build": "webpack --config webpack.renderer.js --mode production",
    "pack:linux": "npm run build && electron-builder --linux",
    "pack:win": "npm run build && electron-builder --win",
    "pack:all": "npm run build && electron-builder --linux --win"
  },
  "build": {
    "appId": "com.zdesktop.agent",
    "productName": "Z Desktop Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "dist/renderer/**/*"
    ],
    "forceCodeSigning": false,
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "icon": "assets/icon.png",
      "maintainer": "Z Desktop Agent",
      "vendor": "Z Desktop Agent",
      "description": "AI Desktop Agent - Controle seu computador com IA"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "sign": false,
      "signAndEditExecutable": false,
      "signDlls": false,
      "signingHashAlgorithms": [],
      "verifyUpdateCodeSignature": false,
      "forceCodeSigning": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "extraResources": []
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "marked": "^14.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "screenshot-desktop": "^1.15.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "autoprefixer": "^10.4.18",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "electron-reload": "^2.0.0-alpha.1",
    "html-webpack-plugin": "^5.6.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.1",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.2"
  }
}
